# ─────────────────────────────────────────────────────────────────────────────
#  PRODUCTION ENVIRONMENT VARIABLES
#  Copy this file, fill in all values, and set them in your deployment platform
#  (Vercel dashboard, Railway variables, Docker --env-file, etc.)
#
#  Do NOT commit the filled-in version — treat it like a password file.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SKIP_AUTH=false                        # MUST be false in production
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com     # Your production URL (https://)
NEXT_PUBLIC_ORG=your-org-slug                      # Your org slug

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...          # Public — safe to expose
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...              # Secret — server-side only

# ── Security ──────────────────────────────────────────────────────────────────
CRON_SECRET=                                       # openssl rand -hex 32
EXPORT_SIGNING_KEY=                                # openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=                             # Set when creating GitHub App

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...

# ── Email ─────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxx
ALERT_FROM_EMAIL=alerts@yourdomain.com

# ── GitHub App ────────────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ── Rate limiting & caching ───────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── Observability ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com    # or https://app.posthog.com

# ── Integrations (all optional) ───────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SCIM_TOKEN=                                        # For SCIM 2.0 provisioning
SCIM_ORG_ID=
GITLAB_WEBHOOK_TOKEN=
GITLAB_API_TOKEN=
BITBUCKET_WEBHOOK_SECRET=
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
